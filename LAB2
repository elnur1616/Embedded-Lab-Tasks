const int xPin = A0;
const int yPin = A1;
const int buttonPin = 2;

const int upLed = 10;
const int downLed = 9;
const int leftLed = 11;
const int rightLed = 6;

void setup() {
  Serial.begin(9600);

  pinMode(xPin, INPUT);
  pinMode(yPin, INPUT);
  pinMode(buttonPin, INPUT_PULLUP);

  pinMode(upLed, OUTPUT);
  pinMode(downLed, OUTPUT);
  pinMode(leftLed, OUTPUT);
  pinMode(rightLed, OUTPUT);
}

void loop() {
  int xVal = analogRead(xPin);
  int yVal = analogRead(yPin);
  int buttonState = digitalRead(buttonPin);

  // If the button is pressed, all LEDs should turn on at full brightness.
  if (buttonState == LOW) {
    digitalWrite(upLed, HIGH);
    digitalWrite(downLed, HIGH);
    digitalWrite(leftLed, HIGH);
    digitalWrite(rightLed, HIGH);
  } else {
    // Map joystick values to brightness
    int upBrightness = map(yVal, 512, 0, 0, 255);
    int downBrightness = map(yVal, 512, 1023, 0, 255);
    int leftBrightness = map(xVal, 512, 0, 0, 255);
    int rightBrightness = map(xVal, 512, 1023, 0, 255);

    // Limit the values to stay within the valid PWM range of 0 to 255.
    upBrightness = constrain(upBrightness, 0, 255);
    downBrightness = constrain(downBrightness, 0, 255);
    leftBrightness = constrain(leftBrightness, 0, 255);
    rightBrightness = constrain(rightBrightness, 0, 255);

    // LED control based on joystick direction
    if (yVal < 500) {
      analogWrite(upLed, upBrightness);
    } else {
      analogWrite(upLed, 0);
    }

    if (yVal > 524) {
      analogWrite(downLed, downBrightness);
    } else {
      analogWrite(downLed, 0);
    }

    if (xVal < 500) {
      analogWrite(leftLed, leftBrightness);
    } else {
      analogWrite(leftLed, 0);
    }

    if (xVal > 524) {
      analogWrite(rightLed, rightBrightness);
    } else {
      analogWrite(rightLed, 0);
    }
  }

  delay(10); 
}
