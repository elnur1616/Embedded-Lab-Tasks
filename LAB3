#include <Wire.h>
#include <LedControl.h>

const int PIN_SQW    = 2;   // DS1307 SQW -> D2
const int PIN_BUTTON = 5;   // Button -> D5 to GND

// MAX7219 dot matrix: DIN=11, CLK=13, CS=10
LedControl lc = LedControl(11, 13, 10, 1);


const int MAX_VALUE = 15;            // count 0..15
const int PRESS_TARGET = 10;         // must be pressed at 10
const unsigned long STEP_MS   = 500; // time per number
const unsigned long WINDOW_MS = 300; // easier margin (increase to 400/500 if needed)

// DS1307 SQW set to 4kHz. With CHANGE interrupt:
// 4kHz square wave => 8000 edges/sec => 8 edges per ms
const unsigned long EDGES_PER_MS = 8;

//sqw edge counter
volatile unsigned long edgeCount = 0;
void onSQW() { edgeCount++; }

unsigned long readEdges() {
  noInterrupts();
  unsigned long e = edgeCount;
  interrupts();
  return e;
}

// DS1307 CONFIG 
void enableSQW_4kHz() {
  Wire.beginTransmission(0x68);
  Wire.write(0x07);   // control register
  Wire.write(0x11);   // SQWE=1, RS1=0, RS0=1 => 4kHz
  Wire.endTransmission();
}

// button (edge + debounce)
bool pressedEvent() {
  static bool last = HIGH;
  bool now = digitalRead(PIN_BUTTON);

  if (last == HIGH && now == LOW) {
    delay(200); // debounce
    last = now;
    return true;
  }
  last = now;
  return false;
}

