void showValue(int v) {
  if (v <= 9) drawDigit(v);
  else if (v == 10) drawTen();
  else if (v == 11) drawEleven();
  else if (v == 12) drawTwelve();
  else if (v == 13) drawThirteen();
  else if (v == 14) drawFourteen();
  else drawFifteen();
}

void blinkTen(int times) {
  for (int i = 0; i < times; i++) {
    lc.clearDisplay(0);
    delay(300);
    drawTen();
    delay(300);
  }
}

// Vairables of game
bool running = false;
unsigned long startEdges = 0;
int value = 0;

void resetGame() {
  noInterrupts();
  edgeCount = 0;
  interrupts();

  running = false;
  value = 0;
  showValue(0);
}

void setup() {
  pinMode(PIN_BUTTON, INPUT_PULLUP);
  pinMode(PIN_SQW, INPUT_PULLUP);   // open-drain line

  Wire.begin();
  enableSQW_4kHz();

  attachInterrupt(digitalPinToInterrupt(PIN_SQW), onSQW, CHANGE);

  lc.shutdown(0, false);
  lc.setIntensity(0, 8);
  lc.clearDisplay(0);

  resetGame();
}

void loop() {
  unsigned long eNow = readEdges();

  // Start/Stop button
  if (pressedEvent()) {
    if (!running) {
      // START
      running = true;
      startEdges = eNow;
      value = 0;
      showValue(0);
    } else {
      // STOP + EVALUATE
      unsigned long elapsedEdges = eNow - startEdges;

      unsigned long targetMs    = (unsigned long)PRESS_TARGET * STEP_MS;
      unsigned long targetEdges = targetMs * EDGES_PER_MS;
      unsigned long windowEdges = WINDOW_MS * EDGES_PER_MS;

      long errEdges = (long)elapsedEdges - (long)targetEdges;
      if (errEdges < 0) errEdges = -errEdges;

      // Freeze display 
      unsigned long elapsedMs = elapsedEdges / EDGES_PER_MS;
      int stoppedValue = (int)(elapsedMs / STEP_MS);
      if (stoppedValue > MAX_VALUE) stoppedValue = MAX_VALUE;
      showValue(stoppedValue);

      delay(400);

      // Blink result using "10"
      if ((unsigned long)errEdges <= windowEdges) blinkTen(2); 
      else blinkTen(3);                                      

      delay(500);
      resetGame();
    }
  }

  // While running, update display
  if (running) {
    unsigned long elapsedEdges = eNow - startEdges;
    unsigned long elapsedMs = elapsedEdges / EDGES_PER_MS;

    int newValue = (int)(elapsedMs / STEP_MS);
    if (newValue > MAX_VALUE) newValue = MAX_VALUE;

    if (newValue != value) {
      value = newValue;
      showValue(value);
    }
  }
}
